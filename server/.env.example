# Copie ce fichier en ".env" (local) ou configure ces variables sur Render/Koyeb.

# Base PostgreSQL GRATUITE : Neon.tech ou Supabase.
#  - Neon    : Dashboard -> Connection string (coche "Pooled", garde ?sslmode=require)
#  - Supabase: Project Settings -> Database -> Connection string (URI)
# Laisse vide pour désactiver la persistance (le serveur reste un simple relais).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port d'écoute. En local : 8787. Sur Render/Koyeb : fourni automatiquement via PORT.
PORT=8787

# Mettre "production" en hébergement pour activer le rate limiting (activé par
# défaut hors dev). En dev local il est désactivé automatiquement.
NODE_ENV=production

# --- Rate limiting (toutes optionnelles : valeurs par défaut saines) ---------
# Désactive complètement le rate limiting (exemption dev/tests).
# RATE_LIMIT_DISABLED=1
# API HTTP publiques (/, /health) : requêtes max par fenêtre et par IP.
# RL_HTTP_WINDOW_MS=60000
# RL_HTTP_MAX=120
# Temps réel (Socket.io) :
# RL_SOCKET_MSG_PER_SEC=30      # anti-flood : messages/s par socket
# RL_CONN_WINDOW_MS=60000       # fenêtre des connexions par IP
# RL_CONN_MAX=60                # connexions max/fenêtre/IP (anti-DDoS basique)
# RL_CREATE_PER_MIN=20          # créations de partie/min/IP
# RL_JOIN_PER_MIN=60            # tentatives de join/min/IP
# Nombre de joueurs max par salon.
# MAX_PLAYERS=12

# NOTE multi-instances : les compteurs sont en mémoire (une seule instance).
# Pour scaler horizontalement, brancher un store partagé (Redis) côté
# express-rate-limit et pour les fenêtres Socket.io.
