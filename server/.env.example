# Copie ce fichier en ".env" (local) ou configure ces variables sur Render/Koyeb.

# Base PostgreSQL GRATUITE : Neon.tech ou Supabase.
#  - Neon    : Dashboard -> Connection string (coche "Pooled", garde ?sslmode=require)
#  - Supabase: Project Settings -> Database -> Connection string (URI)
# Laisse vide pour désactiver la persistance (le serveur reste un simple relais).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port d'écoute. En local : 8787. Sur Render/Koyeb : fourni automatiquement via PORT.
PORT=8787
