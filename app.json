{
  "expo": {
    "name": "Action ou Vérité",
    "slug": "action-ou-verite",
    "scheme": "actionouverite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0F",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B0B0F",
      "resizeMode": "contain",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "twitter",
          "twitterauth",
          "instagram",
          "instagram-stories",
          "fb",
          "fbapi",
          "facebook",
          "tiktok",
          "musically",
          "snssdk1233",
          "snapchat",
          "discord"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.anonymous.actionouverite"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E8322D",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.actionouverite"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidSocialQueries"
    ],
    "extra": {
      "eas": {
        "projectId": "61b62514-cffc-4227-ace6-5842cb27fd27"
      }
    }
  }
}
